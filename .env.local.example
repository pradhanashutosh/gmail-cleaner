# Copy to .env.local and fill in.
# Get OAuth credentials from https://console.cloud.google.com/apis/credentials
# See README for full setup steps.

AUTH_SECRET=             # generate with: openssl rand -base64 32
AUTH_GOOGLE_ID=          # OAuth 2.0 Client ID
AUTH_GOOGLE_SECRET=      # OAuth 2.0 Client Secret
NEXTAUTH_URL=http://localhost:3000
